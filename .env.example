# ============================================================
# RainMachine — Environment Variables Example
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# --- Supabase (all apps) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CEO_APP_URL=http://localhost:3001
NEXT_PUBLIC_ONBOARDING_APP_URL=http://localhost:3002

# --- Onboarding (apps/onboarding only) ---
ONBOARDING_JWT_SECRET=your-32-char-minimum-secret-here

# --- Node ---
NODE_ENV=development
